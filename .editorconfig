# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Go files: tabs (gofmt-enforced)
[*.go]
indent_style = tab

# Makefiles require literal tabs for recipe lines
[Makefile]
indent_style = tab

# Gherkin: 2-space (matches existing features/*.feature)
[*.feature]
indent_size = 2

# Markdown: trailing whitespace can be a meaningful linebreak, leave it alone
[*.md]
trim_trailing_whitespace = false
